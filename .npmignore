# Source (only dist/ is published)
src/
tsconfig.json

# Tests (defense-in-depth: tsconfig excludes them from the build,
# these rules catch them if they ever slip back into dist/)
dist/**/__tests__/
dist/**/__mocks__/
**/*.test.js
**/*.test.d.ts
**/*.spec.js
**/*.spec.d.ts

# Environment
.env
.env.*
.env.example

# Development
node_modules/
.vscode/
.idea/
.claude/
.dual-graph/
.qwen/

# Install scripts (not needed in npm package)
install.bat
install.sh

# Docs not needed at runtime
CLAUDE.md
GEMINI.md
CONTRIBUTING.md
FEATURES.md
docs/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
