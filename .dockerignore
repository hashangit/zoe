# =============================================================================
# Zoe Docker Ignore — Exclude development-only files from build context
# =============================================================================

# Version control
.git
.gitignore
.github

# Dependencies (rebuilt inside the container)
node_modules

# Build output (rebuilt inside the container)
dist

# TypeScript source (not needed at runtime — dist/ is used instead)
src
tsconfig.json
*.ts
!*.d.ts

# Development tools and IDE configs
.claude
.dual-graph
.qwen
.vscode
.idea
*.swp
*.swo
*~

# Documentation site source (docs are published separately)
docs

# Claude/LLM context files
claude_docs
CLAUDE.md
GEMINI.md

# Homebrew formula (packaged separately)
homebrew

# OS-generated files
.DS_Store
Thumbs.db

# Environment files (sensitive — mount at runtime via --env-file)
.env
.env.*
!.env.example

# Test and CI artifacts
coverage
.nyc_output
test-results
playwright-report

# Docker files themselves (no recursion needed)
Dockerfile
docker-compose.yml
docker-compose*.yml
.dockerignore

# Misc development files
*.log
npm-debug.log*
pnpm-debug.log*
CHANGELOG.md
CONTRIBUTING.md
FEATURES.md
CONTEXT.md

# Install scripts (not needed in Docker)
install.sh
install.bat

# npm packaging
.npmignore
